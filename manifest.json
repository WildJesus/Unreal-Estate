{
  "manifest_version": 3,
  "name": "Unreal Estate",
  "version": "1.0.3",
  "description": "Czech housing affordability in historical context — see what any property should cost today to match past mortgage burden. Not affiliated with Sreality.cz or Seznam.cz.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Srealitky Universes",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.sreality.cz/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.js", "data/*.json"],
      "matches": ["https://www.sreality.cz/*"]
    }
  ]
}
